    }
   ],
   "source": [
    "plt.figure()\n",
    "plt.plot(orig_10[\"time_sec\"], orig_10[\"total_probes\"], label=\"Original HULA\")\n",
    "plt.plot(mod_10[\"time_sec\"], mod_10[\"total_probes\"], label=\"Modified HULA\")\n",
    "\n",
    "plt.xlabel(\"Time (seconds)\")\n",
    "plt.ylabel(\"Total Probes\")\n",
    "plt.title(\"Cumulative Probe Count (10% Load)\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "682235c4-f123-4508-8851-0c048705944b",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "plt.figure()\n",
    "plt.boxplot([\n",
    "    orig[\"probes_per_sec\"],\n",
    "    mod[\"probes_per_sec\"]\n",
    "])\n",
    "\n",
    "plt.xticks([1, 2], [\"Original HULA\", \"Modified HULA\"])\n",
    "plt.ylabel(\"Probes per Second\")\n",
    "plt.title(\"Distribution of Probe Rates\")\n",
    "\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "bff909da-395b-4695-a477-d077f81d6ca2",
   "metadata": {},
   "outputs": [],
   "source": [
    "time = np.arange(0, 120)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "1c95ed1b-56bd-4cea-863b-214971b0f980",
   "metadata": {},
   "outputs": [],
   "source": [
    "mod_probe = []\n",
    "current_rate = 5\n",
    "\n",
    "for t in time:\n",
    "    \n",
    "    # Congestion spike between 40s and 70s\n",
    "    if 40 <= t <= 70:\n",
    "        current_rate = 5   # reset to high rate during congestion\n",
    "    \n",
    "    else:\n",
    "        # Exponential backoff during stability\n",
    "        if t % 10 == 0 and current_rate > 1:\n",
    "            current_rate = current_rate / 2\n",
    "        \n",
    "        # Minimum probe rate = 1\n",
    "        if current_rate < 1:\n",
    "            current_rate = 1\n",
    "    \n",
    "    mod_probe.append(current_rate)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "45043229-ee28-4b56-8165-c034b7d114a2",
   "metadata": {},
   "outputs": [],
   "source": [
    "orig_probe = np.ones_like(time) * 5 "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "id": "afd092d2-b635-4a8d-a3f6-d9c5f2ce19f5",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "plt.figure()\n",
    "\n",
    "plt.plot(time, orig_probe, label=\"Original HULA\")\n",
    "plt.plot(time, mod_probe, label=\"Modified HULA\")\n",
    "\n",
    "plt.xlabel(\"Time (seconds)\")\n",
    "plt.ylabel(\"Probes per Second\")\n",
    "plt.title(\"Time-Based Congestion Spike Behavior\")\n",
    " \n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "\n",
    "plt.show()"
   ]
  },
