   "id": "a7e2d6c0-aebc-4975-9efc-55b3c693b7dc",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
