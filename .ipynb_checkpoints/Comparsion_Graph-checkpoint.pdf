  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "e019757a-8b71-4418-9ebc-12259d3eff9e",
   "metadata": {},
   "outputs": [],
   "source": [
    "orig_10 = orig[orig[\"load_percent\"] == 10]\n",
    "mod_10 = mod[mod[\"load_percent\"] == 10]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "6a902947-b1d3-4403-aabf-9434b23581b6",
   "metadata": {},
