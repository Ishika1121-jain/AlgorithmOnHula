    }
   ],
   "source": [
    "plt.figure()\n",
    "plt.plot(orig_10[\"time_sec\"], orig_10[\"overhead\"], label=\"Original HULA\")\n",
    "plt.plot(mod_10[\"time_sec\"], mod_10[\"overhead\"], label=\"Modified HULA\")\n",
    "\n",
    "plt.xlabel(\"Time (seconds)\")\n",
    "plt.ylabel(\"Control Overhead\")\n",
    "plt.title(\"Time vs Control Overhead (10% Load)\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "7ed0541e-4204-4a87-bec4-2836a7c4b392",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "orig_avg = orig.groupby(\"load_percent\")[\"probes_per_sec\"].mean()\n",
    "mod_avg = mod.groupby(\"load_percent\")[\"probes_per_sec\"].mean()\n",
    "\n",
    "plt.figure()\n",
    "plt.plot(orig_avg.index, orig_avg.values, marker='o', label=\"Original HULA\")\n",
    "plt.plot(mod_avg.index, mod_avg.values, marker='o', label=\"Modified HULA\")\n",
    "\n",
    "plt.xlabel(\"Load (%)\")\n",
    "plt.ylabel(\"Average Probes per Second\")\n",
    "plt.title(\"Load vs Average Probe Rate\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "eb4f95a7-28f9-4a7c-88a0-e671a8c031c1",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "orig_over = orig.groupby(\"load_percent\")[\"overhead\"].mean()\n",
    "mod_over = mod.groupby(\"load_percent\")[\"overhead\"].mean()\n",
    "\n",
    "plt.figure()\n",
    "plt.plot(orig_over.index, orig_over.values, marker='o', label=\"Original HULA\")\n",
    "plt.plot(mod_over.index, mod_over.values, marker='o', label=\"Modified HULA\")\n",
    "\n",
    "plt.xlabel(\"Load (%)\")\n",
    "plt.ylabel(\"Average Control Overhead\")\n",
    "plt.title(\"Load vs Control Overhead\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "2a747deb-751a-47d5-89d7-6a72c0cedc36",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "loads = orig_avg.index\n",
    "\n",
    "x = np.arange(len(loads))\n",
    "width = 0.35\n",
    "\n",
    "plt.figure()\n",
    "plt.bar(x - width/2, orig_avg.values, width, label=\"Original HULA\")\n",
    "plt.bar(x + width/2, mod_avg.values, width, label=\"Modified HULA\")\n",
    "\n",
    "plt.xlabel(\"Load (%)\")\n",
    "plt.ylabel(\"Average Probes per Second\")\n",
    "plt.title(\"Probe Rate Comparison (Bar Chart)\")\n",
    "plt.xticks(x, loads)\n",
    "plt.legend()\n",
    "\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
